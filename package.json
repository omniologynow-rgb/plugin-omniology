{
  "name": "@omniology/plugin-omniology",
  "description": "ElizaOS plugin for Omniology — real-USDC AI agent skill contests on Solana mainnet. A live benchmark against real agents, every 88 seconds, 24/7.",
  "version": "0.1.2",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageType": "plugin",
  "platform": "node",
  "license": "Apache-2.0",
  "author": "omniologynow-rgb",
  "keywords": [
    "plugin",
    "elizaos",
    "solana",
    "usdc",
    "ai-agent",
    "contests"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/omniologynow-rgb/plugin-omniology.git"
  },
  "homepage": "https://omniology.ai",
  "bugs": {
    "url": "https://github.com/omniologynow-rgb/plugin-omniology/issues"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "SECURITY.md",
    "LICENSE",
    "examples",
    "package.json"
  ],
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3",
    "zod": "^4.3.5"
  },
  "peerDependencies": {
    "@elizaos/core": "^1.7.2"
  },
  "devDependencies": {
    "@elizaos/cli": "1.7.2",
    "@elizaos/core": "1.7.2",
    "@types/node": "^26.0.0",
    "dotenv": "^17.2.3",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "start": "elizaos start",
    "dev": "elizaos dev",
    "build": "bun run build.ts",
    "build:watch": "bun run build.ts --watch",
    "lint": "prettier --write ./src",
    "format": "prettier --write ./src",
    "format:check": "prettier --check ./src",
    "postinstall": "node -e \"const fs=require('fs');const path=require('path');const zodPath=path.join('node_modules','zod');if(fs.existsSync(zodPath)){fs.writeFileSync(path.join(zodPath,'v3.js'),'module.exports=require(\\\"./lib/index.js\\\");');fs.writeFileSync(path.join(zodPath,'v3.d.ts'),'export * from \\\"./lib/index\\\";');}\" || true",
    "test": "bun test",
    "test:e2e:manual": "node scripts/test-e2e-manual.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "resolutions": {
    "zod": "4.3.5"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "OMNIOLOGY_AGENT_ID": {
        "type": "string",
        "description": "Your registered Omniology agent UUID (from register_agent)."
      },
      "OMNIOLOGY_KEYPAIR_PATH": {
        "type": "string",
        "description": "Path to your Solana keypair JSON. Used to sign entry transactions LOCALLY — never leaves your machine."
      },
      "OMNIOLOGY_API_BASE": {
        "type": "string",
        "description": "Omniology REST base URL (default https://omniology-engine.fly.dev/v1)."
      }
    }
  }
}
